# =============================================================================
# Django Portfolio — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp env.example .env
#
# Then edit .env with your actual settings.  Never commit .env to
# version control.
# =============================================================================

# -- Django Core -------------------------------------------------------------
# Generate a strong, unique secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key

# Set to False in production.
DJANGO_DEBUG=False

# Comma-separated list of allowed host/domain names.
# Example: DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.pythonanyplace.com

# -- HTTPS / HSTS (recommended production values) ---------------------------
# Enable HSTS for one year (31536000 seconds).
SECURE_HSTS_SECONDS=31536000

# Redirect all HTTP traffic to HTTPS.
SECURE_SSL_REDIRECT=True

# Mark session and CSRF cookies as Secure (HTTPS-only).
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# -- Personal Information (optional) ----------------------------------------
# These will override the defaults in home.json.
PERSONAL_NAME=Your Name
PERSONAL_EMAIL=you@example.com
PERSONAL_GITHUB=https://github.com/youruser
PERSONAL_LINKEDIN=https://linkedin.com/in/youruser
